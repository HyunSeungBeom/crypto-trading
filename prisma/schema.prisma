generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  balance       Float     @default(10000000) // 기본 잔고 1,000만원
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  holdings     Holding[]
  transactions Transaction[]
  alerts       PriceAlert[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business Models ───

model Holding {
  id        String   @id @default(cuid())
  userId    String
  symbol    String   // e.g. "BTCUSDT"
  quantity  Float
  avgPrice  Float    // 평균 매수 단가
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}

model Transaction {
  id        String          @id @default(cuid())
  userId    String
  symbol    String
  side      TransactionSide
  quantity  Float
  price     Float           // 체결 가격
  total     Float           // quantity * price
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, symbol])
}

enum TransactionSide {
  BUY
  SELL
}

model PriceAlert {
  id        String         @id @default(cuid())
  userId    String
  symbol    String
  targetPrice Float
  condition AlertCondition
  triggered Boolean        @default(false)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AlertCondition {
  ABOVE
  BELOW
}
